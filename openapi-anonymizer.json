{
  "openapi": "3.0.0",
  "info": {
    "version": "2.x",
    "title": "Presidio Anonymizer API",
    "description": "Anonymizes PII entities detected by the Presidio Analyzer. Supports replace, mask, hash, encrypt, redact, and custom operators. Part of the Microsoft Presidio framework.",
    "contact": {
      "name": "Microsoft Presidio",
      "url": "https://github.com/microsoft/presidio"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5001",
      "description": "Local / Codespaces"
    }
  ],
  "tags": [
    { "name": "Anonymization", "description": "Anonymize and de-anonymize PII in text" },
    { "name": "Operators", "description": "Query supported anonymization operators" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Anonymization"],
        "summary": "Health check",
        "description": "Returns the health status of the Anonymizer service.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "example": "ok" }
              }
            }
          }
        }
      }
    },
    "/anonymize": {
      "post": {
        "tags": ["Anonymization"],
        "summary": "Anonymize PII in text",
        "description": "Anonymizes PII entities in text using results from the Presidio Analyzer. Applies the specified anonymization operator to each detected entity.",
        "operationId": "anonymizeText",
        "requestBody": {
          "description": "Text anonymization request",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/AnonymizeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnonymizeResponse" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/deanonymize": {
      "post": {
        "tags": ["Anonymization"],
        "summary": "De-anonymize text",
        "description": "Reverses anonymization for entities anonymized using the encrypt operator. Requires the same encryption key used during anonymization.",
        "operationId": "deanonymizeText",
        "requestBody": {
          "description": "Text de-anonymization request",
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/DeanonymizeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/AnonymizeResponse" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/anonymizers": {
      "get": {
        "tags": ["Operators"],
        "summary": "List supported anonymizer operators",
        "description": "Returns all anonymization operator types supported by the service.",
        "operationId": "listAnonymizers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperatorsResponse" }
              }
            }
          }
        }
      }
    },
    "/deanonymizers": {
      "get": {
        "tags": ["Operators"],
        "summary": "List supported de-anonymizer operators",
        "description": "Returns all de-anonymization operator types supported by the service.",
        "operationId": "listDeanonymizers",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/OperatorsResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "AnonymizeRequest": {
        "type": "object",
        "title": "AnonymizeRequest",
        "required": ["text", "analyzer_results"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The original text containing PII to anonymize.",
            "example": "Hi, I'm John Smith. My email is john@example.com."
          },
          "anonymizers": {
            "type": "object",
            "title": "Anonymizers",
            "description": "Map of entity type (or DEFAULT) to anonymizer operator config.",
            "additionalProperties": { "$ref": "#/components/schemas/AnonymizerConfig" }
          },
          "analyzer_results": {
            "type": "array",
            "description": "List of PII detections from the Presidio Analyzer /analyze endpoint.",
            "items": { "$ref": "#/components/schemas/AnalyzerResult" }
          }
        }
      },
      "DeanonymizeRequest": {
        "type": "object",
        "title": "DeanonymizeRequest",
        "required": ["text", "anonymizer_results"],
        "properties": {
          "text": {
            "type": "string",
            "description": "The anonymized text to de-anonymize.",
            "example": "Hi, I'm <PERSON>."
          },
          "deanonymizers": {
            "type": "object",
            "title": "Deanonymizers",
            "description": "Map of entity type to decrypt operator config.",
            "additionalProperties": { "$ref": "#/components/schemas/AnonymizerConfig" }
          },
          "anonymizer_results": {
            "type": "array",
            "description": "The items array from the original anonymize response.",
            "items": { "$ref": "#/components/schemas/AnonymizeResultItem" }
          }
        }
      },
      "AnonymizerConfig": {
        "type": "object",
        "title": "AnonymizerConfig",
        "required": ["type"],
        "properties": {
          "type": {
            "type": "string",
            "enum": ["replace", "redact", "hash", "mask", "encrypt", "custom"],
            "description": "The anonymization operator to apply.",
            "example": "replace"
          },
          "new_value": {
            "type": "string",
            "description": "(replace) Value to replace PII with. Defaults to entity type label.",
            "example": "ANONYMIZED"
          },
          "masking_char": {
            "type": "string",
            "description": "(mask) Character to use for masking.",
            "example": "*"
          },
          "chars_to_mask": {
            "type": "integer",
            "description": "(mask) Number of characters to mask.",
            "example": 4
          },
          "from_end": {
            "type": "boolean",
            "description": "(mask) If true, mask from the end of the value.",
            "example": true
          },
          "hash_type": {
            "type": "string",
            "enum": ["md5", "sha256", "sha512"],
            "description": "(hash) The hashing algorithm to use.",
            "example": "sha256"
          },
          "key": {
            "type": "string",
            "description": "(encrypt/decrypt) AES key, 16, 24, or 32 characters.",
            "example": "WmZq4t7w!z%C&F)J"
          }
        }
      },
      "AnalyzerResult": {
        "type": "object",
        "title": "AnalyzerResult",
        "required": ["start", "end", "score", "entity_type"],
        "properties": {
          "start": {
            "type": "integer",
            "description": "Start character index of the entity.",
            "example": 8
          },
          "end": {
            "type": "integer",
            "description": "End character index of the entity.",
            "example": 18
          },
          "score": {
            "type": "number",
            "format": "float",
            "description": "Confidence score between 0.0 and 1.0.",
            "example": 0.85
          },
          "entity_type": {
            "type": "string",
            "description": "The PII entity type.",
            "example": "PERSON"
          }
        }
      },
      "AnonymizeResponse": {
        "type": "object",
        "title": "AnonymizeResponse",
        "properties": {
          "text": {
            "type": "string",
            "description": "The anonymized text.",
            "example": "Hi, I'm <PERSON>. My email is <EMAIL_ADDRESS>."
          },
          "items": {
            "type": "array",
            "description": "Details of each anonymization operation performed.",
            "items": { "$ref": "#/components/schemas/AnonymizeResultItem" }
          }
        }
      },
      "AnonymizeResultItem": {
        "type": "object",
        "title": "AnonymizeResultItem",
        "properties": {
          "operator": { "type": "string", "example": "replace" },
          "entity_type": { "type": "string", "example": "PERSON" },
          "start": { "type": "integer", "example": 8 },
          "end": { "type": "integer", "example": 15 },
          "text": { "type": "string", "example": "<PERSON>" }
        }
      },
      "OperatorsResponse": {
        "type": "object",
        "title": "OperatorsResponse",
        "properties": {
          "operators": {
            "type": "array",
            "description": "List of supported operator names.",
            "items": { "type": "string" },
            "example": ["replace", "redact", "hash", "mask", "encrypt", "custom"]
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "title": "ErrorResponse",
        "properties": {
          "error": {
            "type": "string",
            "example": "Invalid request body"
          }
        }
      }
    }
  }
}
