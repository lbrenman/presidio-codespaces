{
  "openapi": "3.0.0",
  "info": {
    "version": "2.x",
    "title": "Presidio Image Redactor API",
    "description": "Detects and redacts PII text entities in images using OCR and the Presidio Analyzer engine. Supports standard image formats (PNG, JPEG, BMP, TIFF) and DICOM medical images. Part of the Microsoft Presidio framework.",
    "contact": {
      "name": "Microsoft Presidio",
      "url": "https://github.com/microsoft/presidio"
    },
    "license": {
      "name": "MIT",
      "url": "https://opensource.org/licenses/MIT"
    }
  },
  "servers": [
    {
      "url": "http://localhost:5003",
      "description": "Local / Codespaces"
    }
  ],
  "tags": [
    { "name": "Redaction", "description": "Redact PII from images" }
  ],
  "paths": {
    "/health": {
      "get": {
        "tags": ["Redaction"],
        "summary": "Health check",
        "description": "Returns the health status of the Image Redactor service.",
        "operationId": "getHealth",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "text/plain": {
                "schema": { "type": "string", "example": "ok" }
              }
            }
          }
        }
      }
    },
    "/redact": {
      "post": {
        "tags": ["Redaction"],
        "summary": "Redact PII from a standard image",
        "description": "Accepts a standard image file (PNG, JPEG, BMP, TIFF) as multipart form data. Uses OCR to extract text, detects PII with the Presidio Analyzer, and returns a redacted image with PII regions filled with the specified color.",
        "operationId": "redactImage",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/RedactImageRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK - the redacted image binary",
            "content": {
              "image/png": {
                "schema": { "type": "string", "format": "binary" }
              },
              "image/jpeg": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    },
    "/redact-file": {
      "post": {
        "tags": ["Redaction"],
        "summary": "Redact PII from a DICOM image file",
        "description": "Accepts a DICOM (.dcm) medical image file and returns a redacted DICOM file with PII pixel data obscured. Note: redacts pixel data only, not DICOM metadata tags.",
        "operationId": "redactDicomFile",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": { "$ref": "#/components/schemas/RedactDicomRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK - the redacted DICOM file",
            "content": {
              "application/octet-stream": {
                "schema": { "type": "string", "format": "binary" }
              }
            }
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          },
          "500": {
            "description": "Internal Server Error",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/ErrorResponse" }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "RedactImageRequest": {
        "type": "object",
        "title": "RedactImageRequest",
        "required": ["image"],
        "properties": {
          "image": {
            "type": "string",
            "format": "binary",
            "description": "The image file to redact. Supported: PNG, JPEG, BMP, TIFF."
          },
          "data": {
            "type": "string",
            "description": "JSON string of redaction options: color_fill (int or RGB array), score_threshold (float), entities (string array), allow_list (string array).",
            "example": "{\"color_fill\": 0}"
          }
        }
      },
      "RedactDicomRequest": {
        "type": "object",
        "title": "RedactDicomRequest",
        "required": ["file"],
        "properties": {
          "file": {
            "type": "string",
            "format": "binary",
            "description": "The DICOM (.dcm) file to redact."
          },
          "data": {
            "type": "string",
            "description": "JSON string of DICOM redaction options: fill (contrast or background), padding_width (int), score_threshold (float), entities (string array), allow_list (string array).",
            "example": "{\"fill\": \"contrast\", \"padding_width\": 25}"
          }
        }
      },
      "ErrorResponse": {
        "type": "object",
        "title": "ErrorResponse",
        "properties": {
          "error": {
            "type": "string",
            "example": "Failed to process image: unsupported format"
          }
        }
      }
    }
  }
}
